# ── Supabase (for frontend) ──────────────────────────────────────────────────
# Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Settings > API > Project API Keys > anon/public
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxx...

# ── Supabase (for Netlify Functions only) ───────────────────────────────────
# Settings > API > Project API Keys > service_role (SECRET — never expose to frontend!)
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxx...
